	quest.7C6527B7628D25CA.title: "&cЭнергия &r= &bДвижение&r"
	quest.7CDF2E832772BF94.quest_desc: ["Превращает фильтр устройства в чёрный список"]
	quest.7D667262486940EC.title: "Природа"
	quest.7D98EC845F8F6E98.quest_desc: ["Копирует настройки механизмов для передачи их другим механизмам"]
	quest.7DA8487EF50C3DF2.quest_desc: [
		"Неподалёку от &eхранлища&r, поставте два &aэнергитических пилона&r и по одному блоку стекла на &aпилоны&r. Кликните &6ПКМ&r по &aпилонам&r, если появились частицы, направленные на &eхранилище&r, то это значит что &aпилоны&r подключены к &eхранилищу&r. После этого кликните &6ПКМ&r по блокам стекла для переключения режима работы (&1ввод&r и &4вывод&r)."
		""
		"У пилонов &1ввод&r и &4вывод&r ограничен на 2.1 &4GFE&r/t."
		""
		"Расстояние между &eядром&r и &bстабилизатором&r может быть максимум 7 блоков. "
		"{@pagebreak}"
		"1 уровень:"
		"- 1 &eЯдро&r "
		"- 4 &bСтабилизатора&r"
		"- Хранит 45.5 &4MFE&r"
		""
		"2 уровень:"
		"- 1 &eЯдро&r"
		"- 4 &bСтабилизатора&r"
		"- 6 &dДракониевых блока&r"
		"- Хранит 273 &4MFE&r"
		"{@pagebreak}"
		"3 уровень:"
		"- 1 &eЯдро&r "
		"- 4 &bСтабилизатора&r"
		"- 26 &dДракониевых блока&r"
		"- Хранит 1.64 &4GFE&r"
		""
		"4 уровень:"
		"- 1 &eЯдро&r"
		"- 4 &bСтабилизатора&r"
		"- 54 &dДракониевых блока&r"
		"- 26 &cРедстоуниевых блока&r"
		"- Хранит 9.88 &4GFE&r"
		"{@pagebreak}"
		"5 уровень:"
		"- 1 &eЯдро&r"
		"- 36 &bСтабилизаторов&r"
		"- 90 &dДракониевых блока&r"
		"- 80 &cРедстоуниевых блока&r"
		"- Хранит 59.3 &4GFE&r"
		""
		"6 уровень:"
		"- 1 &eЯдро&r "
		"- 36 &bСтабилизаторов&r"
		"- 150 &dДракониевых блока&r"
		"- 178 &cРедстоуниевых блока&r"
		"- Хранит 356 &4GFE&r"
		"{@pagebreak}"
		"7 уровень:"
		"- 1 &eЯдро&r"
		"- 36 &bСтабилизаторов&r"
		"- 210 &dДракониевых блока&r"
		"- 328 &cРедстоуниевых блока&r"
		"- Хранит 2.14 &4TFE&r"
		""
		"8 уровень:"
		"- 1 &eЯдро&r "
		"- 36 &bСтабилизаторов&r"
		"- 786 &dДракониевых блока&r"
		"- 378 &6Пробуждённых дракониевых блока&r"
		"- Хранит &zбесконечность&r &4FE&r"
	]
