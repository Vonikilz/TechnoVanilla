	quest.306A96E63B280016.title: "Электро-твёрдотоплевная печка"
	quest.3083B82B0747DC8B.quest_desc: ["Используется только для СОЕДИНЕНИЯ кристаллов. Для настройки режимов кристалов Shift+ПКМ пустой рукой. Режим принимать для передачи FE. Режим отдать для отдачи."]
